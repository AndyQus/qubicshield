# QubicShield — Environment Configuration
# Copy this file to .env and fill in the values after testnet deploy.

# ── Qubic RPC ────────────────────────────────────────────────────────────────
# Testnet: https://testnet-rpc.qubic.org
# Mainnet: https://rpc.qubic.org
QUBIC_RPC=https://testnet-rpc.qubic.org

# ── Smart Contract (fill after deploy) ───────────────────────────────────────
# 60-character public ID of the deployed QubicShield contract
SC_ADDRESS=REPLACE_AFTER_DEPLOY

# Numeric index assigned to the contract at deployment (e.g. 1, 42, ...)
SC_INDEX=0

# ── Server mode ───────────────────────────────────────────────────────────────
# Set to "true" to use the real Qubic SC instead of the in-memory mock.
# Requires SC_ADDRESS and SC_INDEX to be set correctly.
USE_REAL_SC=false
